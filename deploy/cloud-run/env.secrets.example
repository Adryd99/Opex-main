# Copy this file to `deploy/cloud-run/env.secrets.local` for local planning.
# Keep the real file out of git.
# The values below are placeholders for the real secret values you will later push to Secret Manager.

APP_PG_PASSWORD=GENERATE_A_RANDOM_DATABASE_PASSWORD
KEYCLOAK_DB_PASSWORD=GENERATE_A_RANDOM_DATABASE_PASSWORD
POSTGRES_SUPERUSER_PASSWORD=GENERATE_A_RANDOM_POSTGRES_PASSWORD
KC_ADMIN=CHOOSE_A_BOOTSTRAP_ADMIN_USERNAME
KC_ADMIN_PW=GENERATE_A_RANDOM_BOOTSTRAP_ADMIN_PASSWORD

SALTEDGE_APP_ID=SET_REAL_SALTEDGE_APP_ID
SALTEDGE_SECRET=SET_REAL_SALTEDGE_SECRET

OPEX_SMTP_USERNAME=SET_REAL_SMTP_USERNAME
OPEX_SMTP_PASSWORD=SET_REAL_SMTP_PASSWORD

OPEX_GOOGLE_CLIENT_ID=SET_REAL_GOOGLE_CLIENT_ID
OPEX_GOOGLE_CLIENT_SECRET=SET_REAL_GOOGLE_CLIENT_SECRET
