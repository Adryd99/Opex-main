# Copy this file to `deploy/cloud-run/env.web` before a production build/deploy.
# These values are loaded by:
# - `build-images.ps1` for the frontend image build
# - `deploy-web.ps1` for the Cloud Run deploy metadata
#
# Do not put secrets here.
# Any `VITE_*` value can end up embedded in the browser bundle.

PROJECT_ID=opex-v1-493608
REGION=us-central1
REPOSITORY=opex
SERVICE_NAME=opex-web
IMAGE_TAG=latest
MAX_INSTANCES=2

APP_DOMAIN=opex.dani.host
API_DOMAIN=api.opex.dani.host
AUTH_DOMAIN=auth.opex.dani.host

VITE_API_BASE_URL=https://api.opex.dani.host
VITE_API_ORIGIN=https://api.opex.dani.host

VITE_KEYCLOAK_AUTH_URL=https://auth.opex.dani.host/realms/opex/protocol/openid-connect/auth
VITE_KEYCLOAK_TOKEN_URL=https://auth.opex.dani.host/realms/opex/protocol/openid-connect/token
VITE_KEYCLOAK_LOGOUT_URL=https://auth.opex.dani.host/realms/opex/protocol/openid-connect/logout
VITE_KEYCLOAK_CLIENT_ID=opex
VITE_KEYCLOAK_SCOPE=openid profile email
VITE_KEYCLOAK_REDIRECT_URI=https://opex.dani.host
