# Copy this file to `deploy/cloud-run/env.web` before a production build/deploy.
# These values are loaded by:
# - `build-images.ps1` for the frontend image build
# - `deploy-web.ps1` for the Cloud Run deploy metadata
#
# Do not put secrets here.
# Any `VITE_*` value can end up embedded in the browser bundle.

PROJECT_ID=your-gcp-project-id
REGION=europe-west1
REPOSITORY=opex
SERVICE_NAME=opex-web
IMAGE_TAG=latest
MAX_INSTANCES=2

APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
AUTH_DOMAIN=auth.example.com

VITE_API_BASE_URL=https://api.example.com
VITE_API_ORIGIN=https://api.example.com

VITE_KEYCLOAK_AUTH_URL=https://auth.example.com/realms/opex/protocol/openid-connect/auth
VITE_KEYCLOAK_TOKEN_URL=https://auth.example.com/realms/opex/protocol/openid-connect/token
VITE_KEYCLOAK_LOGOUT_URL=https://auth.example.com/realms/opex/protocol/openid-connect/logout
VITE_KEYCLOAK_CLIENT_ID=opex
VITE_KEYCLOAK_SCOPE=openid profile email
VITE_KEYCLOAK_REDIRECT_URI=https://app.example.com
