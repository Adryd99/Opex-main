# Reference only. These values document the non-secret Keycloak settings.
# They are not loaded automatically by the deploy scripts.

KC_DB=postgres
KC_DB_URL=jdbc:postgresql://10.20.0.3:5432/keycloak
KC_DB_USERNAME=keycloak

OPEX_APP_ORIGIN=https://opex.dani.host
OPEX_APP_ORIGIN_WILDCARD=https://opex.dani.host/*
OPEX_LEGAL_APP_BASE_URL=https://opex.dani.host
OPEX_LEGAL_API_PUBLIC_URL=https://api.opex.dani.host/api/legal/public

KC_HOSTNAME=https://auth.opex.dani.host
KC_LOG_LEVEL=INFO

KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true

# Optional non-secret production realm inputs.
# These are consumed by deploy/cloud-run/apply-auth-production-settings.ps1,
# not directly by the Cloud Run deploy scripts.
OPEX_SMTP_HOST=smtp.gmail.com
OPEX_SMTP_PORT=587
OPEX_SMTP_FROM=noreply@opex.dani.host
OPEX_SMTP_FROM_DISPLAY_NAME=Opex
OPEX_SMTP_ENCRYPTION=StartTLS
