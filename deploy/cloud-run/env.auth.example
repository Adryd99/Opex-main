# Copy this file to `deploy/cloud-run/env.auth`.
# `deploy-auth.ps1` and `apply-auth-production-settings.ps1` read this file automatically.

PROJECT_ID=opex-v1-493608
REGION=us-central1
REPOSITORY=opex
SERVICE_NAME=opex-auth
IMAGE_TAG=latest
MAX_INSTANCES=2

NETWORK=opex-vpc
SUBNET=opex-us-central1

APP_DOMAIN=opex.dani.host
API_DOMAIN=api.opex.dani.host
AUTH_DOMAIN=auth.opex.dani.host

KEYCLOAK_DB_HOST=10.20.0.3
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak

KC_HOSTNAME=https://auth.opex.dani.host
KC_LOG_LEVEL=INFO
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true

OPEX_APP_ORIGIN=https://opex.dani.host
OPEX_APP_ORIGIN_WILDCARD=https://opex.dani.host/*
OPEX_LEGAL_APP_BASE_URL=https://opex.dani.host
OPEX_LEGAL_API_PUBLIC_URL=https://api.opex.dani.host/api/legal/public

# Production realm apply settings.
REALM=opex
ADMIN_REALM=master

# Optional non-secret SMTP realm inputs used by apply-auth-production-settings.ps1.
OPEX_SMTP_HOST=smtp.gmail.com
OPEX_SMTP_PORT=587
OPEX_SMTP_FROM=noreply@opex.dani.host
OPEX_SMTP_FROM_DISPLAY_NAME=Opex
OPEX_SMTP_ENCRYPTION=StartTLS
OPEX_SMTP_USE_AUTHENTICATION=true
