# Template for `deploy/cloud-run/local/env.auth.secrets`.
# In the preferred flow this file is generated by `generate-deploy-env.ps1`.
# `deploy-auth.ps1` and `apply-auth-production-settings.ps1` read this file automatically.
#
# These are Secret Manager secret names, not the secret values.
# The actual secret values must already exist in Google Secret Manager before deploy/apply.

KC_ADMIN_SECRET=KC_ADMIN
KC_ADMIN_PASSWORD_SECRET=KC_ADMIN_PW
KEYCLOAK_DB_PASSWORD_SECRET=KEYCLOAK_DB_PASSWORD
OPEX_SMTP_USERNAME_SECRET=OPEX_SMTP_USERNAME
OPEX_SMTP_PASSWORD_SECRET=OPEX_SMTP_PASSWORD
OPEX_GOOGLE_CLIENT_ID_SECRET=OPEX_GOOGLE_CLIENT_ID
OPEX_GOOGLE_CLIENT_SECRET_SECRET=OPEX_GOOGLE_CLIENT_SECRET
