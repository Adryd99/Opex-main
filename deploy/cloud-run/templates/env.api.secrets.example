# Template for `deploy/cloud-run/local/env.api.secrets`.
# In the preferred flow this file is generated by `generate-deploy-env.ps1`.
# `deploy-api.ps1` reads this file automatically when `-SecretsFile` is not overridden.
#
# These are Secret Manager secret names, not the secret values.
# The actual secret values must exist in Google Secret Manager before deploy.

APP_PG_PASSWORD_SECRET=APP_PG_PASSWORD
KC_ADMIN_SECRET=KC_ADMIN
KC_ADMIN_PASSWORD_SECRET=KC_ADMIN_PW
SALTEDGE_APP_ID_SECRET=SALTEDGE_APP_ID
SALTEDGE_SECRET_SECRET=SALTEDGE_SECRET
