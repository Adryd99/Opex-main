# Template for `deploy/cloud-run/local/env.auth`.
# In the preferred flow this file is generated by `generate-deploy-env.ps1`.
#
# All values here are non-secret placeholders.
# Replace them for the target production stack before running the scripts.

PROJECT_ID=your-gcp-project-id
REGION=europe-west1
REPOSITORY=opex
SERVICE_NAME=opex-auth
IMAGE_TAG=latest
MAX_INSTANCES=2

NETWORK=your-vpc-name
SUBNET=your-subnet-name

APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
AUTH_DOMAIN=auth.example.com

KEYCLOAK_DB_HOST=SET_AFTER_CLOUD_SQL_PRIVATE_IP
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak

KC_HOSTNAME=https://auth.example.com
KC_LOG_LEVEL=INFO
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true

OPEX_APP_ORIGIN=https://app.example.com
OPEX_APP_ORIGIN_WILDCARD=https://app.example.com/*
OPEX_LEGAL_APP_BASE_URL=https://app.example.com
OPEX_LEGAL_API_PUBLIC_URL=https://api.example.com/api/legal/public

# Production realm apply settings.
REALM=opex
ADMIN_REALM=master

# Optional non-secret SMTP realm inputs used by apply-auth-production-settings.ps1.
# If you do not want SMTP on the first deploy, leave the values blank and skip -ApplySmtp.
OPEX_SMTP_HOST=smtp.example.com
OPEX_SMTP_PORT=587
OPEX_SMTP_FROM=noreply@example.com
OPEX_SMTP_FROM_DISPLAY_NAME=Opex
OPEX_SMTP_ENCRYPTION=StartTLS
OPEX_SMTP_USE_AUTHENTICATION=true
