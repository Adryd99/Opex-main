# Copy this file to `deploy/cloud-run/local/stack.local` for local planning.
# This file is not read directly by the deploy scripts.
# It exists to keep the next production stack decisions in one place.

PROJECT_ID=your-gcp-project-id
REGION=europe-west1
REPOSITORY=opex

NETWORK=your-vpc-name
SUBNET=your-subnet-name
SUBNET_RANGE=10.20.0.0/24

BASE_DOMAIN=example.com
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
AUTH_DOMAIN=auth.example.com

SQL_INSTANCE=your-cloud-sql-instance-name
APP_DB=opexdb
APP_DB_USER=opex
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
SQL_PRIVATE_IP=SET_AFTER_CLOUD_SQL_PRIVATE_IP

REALM=opex
WEB_CLIENT_ID=opex
