# Copy this file to `opex-web/.env` only if you want to override local frontend defaults.
# No secrets should ever be stored here.

VITE_API_BASE_URL=
VITE_API_ORIGIN=http://localhost:8080

VITE_KEYCLOAK_AUTH_URL=http://localhost:8081/realms/opex/protocol/openid-connect/auth
VITE_KEYCLOAK_TOKEN_URL=/keycloak/realms/opex/protocol/openid-connect/token
VITE_KEYCLOAK_LOGOUT_URL=http://localhost:8081/realms/opex/protocol/openid-connect/logout
VITE_KEYCLOAK_CLIENT_ID=opex
VITE_KEYCLOAK_SCOPE=openid profile email
VITE_KEYCLOAK_REDIRECT_URI=http://localhost:3000
