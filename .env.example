# Copy this file to `.env` for local development.
# The root `.env` is consumed by:
# - `docker-compose.yml`
# - `opex-api` local property loading
# - local auth bootstrap scripts
#
# It is not consumed by `opex-web`.
# The frontend reads its own optional env overrides from `opex-web/.env`.

# Infrastructure images
KC_IMAGE=quay.io/keycloak/keycloak:26.4.0
PG_IMAGE=postgres:16.4-alpine
TZ=UTC

# Local Keycloak database
KEY_PG_USER=keycloak
KEY_PG_PASSWORD=keycloak
KEY_PG_DB=keycloak

# Local Keycloak bootstrap admin
KC_ADMIN=admin
KC_ADMIN_PW=admin

# Local application database
APP_PG_HOST=localhost
APP_PG_PORT=5433
APP_PG_USER=opex
APP_PG_PASSWORD=opex
APP_PG_DB=opexdb

# Local backend / auth settings
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
APP_WEB_BASE_URL=http://localhost:3000
APP_USER_DEFAULT_VAT_FREQUENCY=Yearly

KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/opex
KEYCLOAK_SERVER_URL=http://localhost:8081
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_TARGET_REALM=opex
KEYCLOAK_WEB_CLIENT_ID=opex
KEYCLOAK_VERIFY_EMAIL_LIFESPAN_SECONDS=43200

# Local Salt Edge placeholders
SALTEDGE_APP_ID=replace-me
SALTEDGE_SECRET=replace-me
SALTEDGE_RETURN_TO_URL=http://localhost:3000/success

# Optional legal metadata overrides
LEGAL_CONTROLLER_NAME=Opex
LEGAL_CONTROLLER_ADDRESS=Configure before production go-live
LEGAL_PRIVACY_EMAIL=privacy@opex.local
LEGAL_DPO_EMAIL=dpo@opex.local
LEGAL_SUPPORT_EMAIL=support@opex.local
LEGAL_SUPERVISORY_AUTHORITY=Configure your lead supervisory authority before go-live

LEGAL_POLICY_LAST_UPDATED=2026-04-09
LEGAL_PRIVACY_VERSION=2026-04-09
LEGAL_TERMS_VERSION=2026-04-09
LEGAL_COOKIE_VERSION=2026-04-09
LEGAL_OPEN_BANKING_VERSION=2026-04-09

LEGAL_RETENTION_ACTIVE_ACCOUNT=Retained while the account stays active and for up to 30 days after closure unless a longer statutory period applies.
LEGAL_RETENTION_CLOSED_ACCOUNT=Core billing, financial or tax records may be retained for the period required by applicable accounting and tax laws.
LEGAL_RETENTION_OPEN_BANKING=Retained while the related connection stays active and then removed or anonymized according to closure and statutory retention rules.
LEGAL_RETENTION_CONSENT_AUDIT=Retained for the lifetime of the account and for up to 6 years after closure to evidence policy acceptance history where needed.
